# --- Required (production) ---
NODE_ENV=production
PORT=3000

# Public URL of the site (used for links/cookies)
APP_URL=https://goldendallah.sa

# OAuth base URL (if you use OAuth flows)
OAUTH_SERVER_URL=https://goldendallah.sa

# MySQL connection string
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB_NAME"

# Must be long/secure (>= 32 chars)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Owner identity (used for owner-only operations)
OWNER_OPEN_ID=your_owner_open_id
OWNER_EMAIL=owner@goldendallah.sa

# Admin account (used for initial admin login / enforced in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
ADMIN_EMAIL=admin@goldendallah.sa

# Uploads path on disk (must be writable)
UPLOADS_DIR=uploads

# --- Optional: email notifications ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Optional: WhatsApp notifications (webhook sender) ---
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_FROM_LABEL=Golden Dallah

# --- Optional: Forge/AI services (only required if those features are used) ---
FORGE_API_URL=
FORGE_API_KEY=

# --- Dev only (ignored in production) ---
ADMIN_BYPASS_KEY=dev-key-change-me

